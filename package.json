{
  "name": "tokenplan-usage-hud",
  "version": "0.1.20",
  "private": true,
  "description": "Claude Code statusline plugin that renders MiniMax token-plan usage (5h + weekly) or DeepSeek account balance, picked by ANTHROPIC_BASE_URL. Composes with another statusline via the TOKENPLAN_UPSTREAM_CMD env var.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx src/**/*.test.ts",
    "settings:install": "bash scripts/install.sh",
    "settings:install:project": "bash scripts/install.sh --project",
    "settings:uninstall": "bash scripts/install.sh --uninstall",
    "settings:restore": "bash scripts/install.sh --restore",
    "settings:clean": "bash scripts/clean.sh",
    "settings:clean:dry": "bash scripts/clean.sh --dry-run",
    "dev:uninstall": "bash scripts/dev-uninstall.sh",
    "dev:uninstall:dry": "bash scripts/dev-uninstall.sh --dry-run"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}